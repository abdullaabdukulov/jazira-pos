# URY POS — Server sozlamalari
# Ushbu faylni .env nomi bilan saqlang va qiymatlarni to'ldiring.
# MUHIM: Bu faylni Git ga yuklamang!

# Frappe/ERPNext server manzili (oxirida / bo'lmasin)
FRAPPE_URL=https://yoursite.erpcontrol.uz

# Kassir/sistem foydalanuvchisi credentials
FRAPPE_USER=cashier@example.com
FRAPPE_PASSWORD=your_password_here

# Multi-site bench uchun sayt nomi (odatda bo'sh qoldiriladi)
FRAPPE_SITE=

# API token autentifikatsiya (ixtiyoriy, user/password o'rniga)
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
